# Supabase (Postgres) — pooler 経由 / migrate は直結
DATABASE_URL="postgresql://...pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://...supabase.com:5432/postgres"

# LINE Login / 検証（LIFF のトークン検証にも使用）
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""

# LINE Messaging API（出面グループへの push / リッチメニュー作成）
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_GROUP_ID=""

# LIFF（入力フォーム）
NEXT_PUBLIC_LIFF_ID=""

# 管理者の LINE userId（カンマ区切り・初期 ADMIN 付与用 / seed で使用）
ADMIN_LINE_USER_IDS=""

# ── 管理画面ログイン（LINE Login → 署名付きセッション）──
# セッション署名鍵（必須）。32文字以上のランダム値を推奨:
#   openssl rand -hex 32  /  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""
# 管理ログイン専用の LINE Login チャネル（未設定なら LINE_CHANNEL_ID/SECRET を流用）
LINE_LOGIN_CHANNEL_ID=""
LINE_LOGIN_CHANNEL_SECRET=""
# LINE Login のコールバック URL（LINE Developers の Callback URL と完全一致させる）
#   例: https://<your-vercel-domain>/api/auth/line/callback
ADMIN_LOGIN_REDIRECT_URL=""
