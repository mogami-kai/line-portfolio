# Supabase (Postgres) — pooler 経由 / migrate は直結
DATABASE_URL="postgresql://...pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://...supabase.com:5432/postgres"

# ── LINE Login チャネル（例: 出面管理 / LIFF・管理ログインに使用）──
#   このチャネルの ID/SECRET。LIFF アクセストークン検証 と 管理画面 OAuth ログインに使う。
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""

# ── LINE Messaging API チャネル（例: 出面bot / グループ push・リッチメニュー・Webhook）──
LINE_CHANNEL_ACCESS_TOKEN=""
# Webhook 署名検証用 = Messaging API チャネルの「チャネルシークレット」。
#   未設定なら LINE_CHANNEL_SECRET にフォールバック（単一チャネル運用の後方互換）。
LINE_MESSAGING_CHANNEL_SECRET=""
# 出面グループ ID（SELF のログ投稿先）。webhook ログの source.groupId から採取。
LINE_GROUP_ID=""

# LIFF（入力フォーム）
NEXT_PUBLIC_LIFF_ID=""

# 管理者の LINE userId（カンマ区切り・初期 ADMIN 付与用 / seed で使用）
ADMIN_LINE_USER_IDS=""

# ── 管理画面ログイン（LINE Login → 署名付きセッション）──
# セッション署名鍵（必須）。32文字以上のランダム値を推奨:
#   openssl rand -hex 32  /  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""
# 管理ログイン専用に別チャネルを使う場合のみ設定（未設定なら上の LINE_CHANNEL_ID/SECRET を流用）。
LINE_LOGIN_CHANNEL_ID=""
LINE_LOGIN_CHANNEL_SECRET=""
# LINE Login のコールバック URL（LINE Developers の Callback URL と完全一致させる）
#   例: https://line-portfolio.vercel.app/api/auth/line/callback
ADMIN_LOGIN_REDIRECT_URL=""

# ── 一時開放（デモ/検証用・既定OFF）──
#   true の間だけ、LINE ログインした人を全員「管理者」として管理画面に通す。
#   ※ 実データ（職人・取引先・出面・請求）が閲覧/編集/削除できる状態になる。
#   ※ 終わったら必ず外す（未設定/false で「承認済み ADMIN のみ」に即復帰）。
#   値: true/1/on/yes で有効。
OPEN_ADMIN=""
